---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  keywords: string[];
  location?: string;
}

const { title, description, pubDate, keywords, location } = Astro.props;

const canonical = `https://academydaycare.ca${Astro.url.pathname}`;
const formattedDate = pubDate.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Academy Daycare",
    "url": "https://academydaycare.ca"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Academy Daycare",
    "url": "https://academydaycare.ca"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonical
  },
  "keywords": keywords.join(', ')
};
---

<Layout title={`${title} | Academy Daycare Blog`} description={description} canonical={canonical}>
  <head>
    <meta name="keywords" content={keywords.join(', ')} />
    {location && <meta name="geo.placename" content={location} />}
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={pubDate.toISOString()} />
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  </head>

  <Navbar />

  <!-- Hero -->
  <section class="pt-28 pb-16 sm:pt-32 sm:pb-20 bg-brand-dark">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-neutral-500 mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        <span>/</span>
        <span class="text-neutral-400 truncate">{title}</span>
      </nav>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight mb-4">
        {title}
      </h1>
      <time datetime={pubDate.toISOString()} class="text-neutral-500 text-sm font-medium">
        {formattedDate}
      </time>
    </div>
  </section>

  <!-- Content -->
  <article class="bg-white py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none
        prose-headings:font-black prose-headings:text-brand-dark
        prose-h2:text-2xl prose-h2:sm:text-3xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:sm:text-2xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-neutral-700 prose-p:leading-relaxed
        prose-a:text-academy-teal prose-a:font-semibold prose-a:no-underline hover:prose-a:underline
        prose-strong:text-brand-dark prose-strong:font-bold
        prose-ul:text-neutral-700 prose-ol:text-neutral-700
        prose-li:leading-relaxed prose-li:marker:text-academy-teal
        prose-blockquote:border-academy-teal prose-blockquote:text-neutral-600 prose-blockquote:not-italic
        prose-img:rounded-xl prose-img:shadow-lg
        prose-hr:border-neutral-200
      ">
        <slot />
      </div>
    </div>
  </article>

  <!-- CTA -->
  <section class="bg-brand-charcoal py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-black text-white mb-4">
        Ready to Give Your Dog the Best Care?
      </h2>
      <p class="text-neutral-400 text-lg mb-8 max-w-xl mx-auto leading-relaxed">
        Whether it's daycare, boarding, or training — we'd love to meet your dog. Fill out the form below and we'll be in touch.
      </p>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>

<style is:global>
  /* Tailwind typography plugin fallback — manual prose styles */
  .prose h2 { font-size: 1.5rem; line-height: 1.3; margin-top: 3rem; margin-bottom: 1rem; }
  .prose h3 { font-size: 1.25rem; line-height: 1.4; margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose p { margin-bottom: 1.25rem; line-height: 1.8; color: #404040; }
  .prose ul, .prose ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  .prose ul { list-style-type: disc; }
  .prose ol { list-style-type: decimal; }
  .prose li { margin-bottom: 0.5rem; line-height: 1.7; color: #404040; }
  .prose li::marker { color: #0D9488; }
  .prose a { color: #0D9488; font-weight: 600; text-decoration: none; }
  .prose a:hover { text-decoration: underline; }
  .prose strong { color: #1A1A1A; font-weight: 700; }
  .prose blockquote {
    border-left: 4px solid #0D9488;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: #525252;
    font-style: normal;
  }
  .prose img { border-radius: 0.75rem; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); }
  .prose hr { border-color: #e5e5e5; margin: 2rem 0; }
  .prose h2, .prose h3 { font-weight: 900; color: #1A1A1A; }

  @media (min-width: 640px) {
    .prose h2 { font-size: 1.875rem; }
    .prose h3 { font-size: 1.5rem; }
  }
</style>
