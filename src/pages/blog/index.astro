---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export const prerender = true;

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title="Blog | Academy Daycare"
  description="Tips, guides, and insights on dog daycare, training, and boarding from Toronto's premier facility."
  canonical="https://academydaycare.ca/blog"
>
  <Navbar />

  <!-- Hero -->
  <section class="pt-28 pb-16 sm:pt-32 sm:pb-20 bg-brand-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">Blog</span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight mb-4">
        Insights & Tips for Dog Owners
      </h1>
      <p class="text-neutral-400 text-lg max-w-2xl leading-relaxed">
        Expert advice on daycare, training, boarding, and keeping your dog happy and healthy.
      </p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="bg-brand-dark py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-neutral-500 text-lg">No posts yet. Check back soon!</p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group block bg-brand-charcoal rounded-2xl overflow-hidden border border-white/5 hover:border-academy-teal/30 transition-all duration-300"
            >
              <div class="p-6 sm:p-8">
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs font-medium text-neutral-500 uppercase tracking-wider"
                >
                  {post.data.pubDate.toLocaleDateString('en-CA', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                <h2 class="text-xl font-bold text-white mt-3 mb-3 group-hover:text-academy-teal transition-colors leading-snug">
                  {post.data.title}
                </h2>
                <p class="text-neutral-400 text-sm leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>
                <span class="inline-flex items-center gap-1 text-academy-teal text-sm font-semibold mt-4 group-hover:gap-2 transition-all">
                  Read more
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <Footer />
</Layout>
