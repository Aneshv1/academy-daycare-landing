---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const testimonials = [
  {
    name: 'Lisa T.',
    text: 'We went on vacation for 10 days and didn\'t worry once. Our dog was in the same facility she goes to for daycare — same staff, same routine. She came home happy and honestly seemed like she didn\'t miss us at all.',
    detail: 'Golden Retriever, 4y',
  },
  {
    name: 'Raj P.',
    text: 'Most boarding places just kennel your dog all day. Academy includes full daycare activities — play, outdoor time, socialization. My dog actually had a better week than I did.',
    detail: 'Husky, 3y',
  },
  {
    name: 'Emily C.',
    text: 'We board our two dogs here whenever we travel and they always come back calm and happy. The staff send updates which is so reassuring. Worth every penny for the peace of mind.',
    detail: 'Two Poodle mixes, 2y & 5y',
  },
];

const faqs = [
  { q: 'What\'s included with boarding?', a: 'Full daycare activities during the day — structured play, outdoor yard time, socialization, and rest periods. Your dog follows the same routine as our daycare dogs, plus quiet overnight accommodation in private kennels.' },
  { q: 'What are the overnight accommodations like?', a: 'Dogs stay in clean, quiet private kennels with fresh bedding and water. The facility is climate-controlled and secure. Staff ensure every dog is settled and comfortable before closing.' },
  { q: 'Can my dog board if they haven\'t done daycare here before?', a: 'All dogs require an in-person assessment before their first visit — whether it\'s daycare or boarding. This ensures we know your dog\'s temperament and can match them with compatible playmates.' },
  { q: 'Do you offer long-stay discounts?', a: 'Yes — boarding is $75/day for stays under 7 nights, and $65/day for stays of 7 nights or more. The longer your dog stays, the more they settle into the routine.' },
  { q: 'Can I bring my dog\'s food and belongings?', a: 'Yes, please bring your dog\'s regular food to maintain their diet. You\'re welcome to bring a favourite blanket or toy as well — familiar items help dogs settle in faster.' },
  { q: 'What happens on weekends?', a: 'Boarded dogs receive the same level of care on weekends — supervised play, outdoor time, rest periods, and meals. The routine stays consistent every day.' },
];
---

<Layout
  title="Dog Boarding in Gormley, ON | Academy Daycare"
  description="Expert dog boarding with full daycare included. $75/day ($65 for 7+ nights). Private kennels, structured routine, 15-year safety record. Gormley, ON."
  canonical="https://academydaycare.ca/boarding"
>
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-brand-dark pt-24 pb-16 sm:pt-28 sm:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-academy-teal/5 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full mb-6">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" /><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" /><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" /><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" /></svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <span class="text-white text-xs font-bold">4.9/5</span>
            <span class="text-neutral-400 text-xs">250+ Google Reviews</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-black leading-[1.1] tracking-tight mb-6">
            <span class="text-white">Travel Without</span><br />
            <span class="bg-gradient-to-r from-academy-teal to-emerald-400 bg-clip-text text-transparent">the Guilt</span>
          </h1>

          <div class="border-l-2 border-academy-teal/40 pl-4 mb-6">
            <p class="text-neutral-300 text-sm italic">"We went on vacation for 10 days and didn't worry once. She came home happy."</p>
            <p class="text-neutral-500 text-xs mt-1">— Lisa T., Golden Retriever owner</p>
          </div>

          <p class="text-lg text-neutral-300 leading-relaxed mb-8 max-w-xl">
            Leave your dog with the same team they already know and trust. Full daycare activities during the day, quiet private kennels at night — and <strong class="text-white">a perfect 15-year safety record.</strong>
          </p>

          <div class="grid grid-cols-2 gap-x-6 gap-y-3 mb-8">
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Full daycare included</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Private quiet kennels</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Consistent daily routine</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Long-stay discounts</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Weekend care included</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Bring their own food</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 mb-6">
            <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 bg-academy-teal text-white text-base font-bold rounded-xl hover:bg-academy-teal-dark transition-all duration-200 shadow-lg shadow-academy-teal/25">
              Book Boarding
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
            <a href="tel:4377769563" class="inline-flex items-center justify-center px-8 py-4 border border-white/10 text-white text-base font-semibold rounded-xl hover:bg-white/5 transition-all duration-200">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              437-776-9563
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
            <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/e8e502cd-4f6b-4f0e-b57c-e24c072d73fb/440547A1-5801-4012-A881-28733D746BEF.JPG" alt="Dog resting in quiet kennel" class="w-full h-auto object-cover aspect-[4/3]" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/40 via-transparent to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">Pricing</span>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-charcoal mb-4">Boarding Rates</h2>
        <p class="text-lg text-neutral-500">Full daycare activities included with every boarding stay. No extra charges.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-neutral-50 rounded-2xl border border-neutral-200 p-8 text-center">
          <h3 class="text-lg font-bold text-brand-charcoal mb-1">Standard Stay</h3>
          <p class="text-sm text-neutral-500 mb-6">1–6 nights</p>
          <div class="mb-6">
            <span class="text-5xl font-black text-brand-charcoal">$75</span>
            <span class="text-neutral-500 text-sm">/night</span>
          </div>
          <ul class="space-y-2 text-left mb-8">
            <li class="flex items-center gap-2 text-sm text-neutral-600">
              <svg class="w-4 h-4 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Full daycare activities
            </li>
            <li class="flex items-center gap-2 text-sm text-neutral-600">
              <svg class="w-4 h-4 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Private kennel overnight
            </li>
            <li class="flex items-center gap-2 text-sm text-neutral-600">
              <svg class="w-4 h-4 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Weekend care included
            </li>
          </ul>
          <a href="#contact" class="block px-6 py-3 bg-academy-teal text-white text-sm font-bold rounded-lg hover:bg-academy-teal-dark transition-colors">
            Book Now
          </a>
        </div>

        <div class="bg-brand-charcoal rounded-2xl border border-academy-teal/30 p-8 text-center relative">
          <div class="absolute top-4 right-4">
            <span class="px-3 py-1 bg-academy-teal text-white text-xs font-bold rounded-full">Best Value</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-1">Extended Stay</h3>
          <p class="text-sm text-neutral-400 mb-6">7+ nights</p>
          <div class="mb-2">
            <span class="text-5xl font-black text-white">$65</span>
            <span class="text-neutral-400 text-sm">/night</span>
          </div>
          <p class="text-sm text-academy-teal font-semibold mb-6">Save $10/night</p>
          <ul class="space-y-2 text-left mb-8">
            <li class="flex items-center gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Everything in Standard
            </li>
            <li class="flex items-center gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Dog settles into routine
            </li>
            <li class="flex items-center gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Perfect for vacations
            </li>
          </ul>
          <a href="#contact" class="block px-6 py-3 bg-academy-teal text-white text-sm font-bold rounded-lg hover:bg-academy-teal-dark transition-colors">
            Book Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-20 sm:py-24 bg-brand-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">What to Expect</span>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">More Than Just a Place to Sleep</h2>
        <p class="text-lg text-neutral-400">Your dog gets the full Academy experience — not just a kennel.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-brand-charcoal rounded-2xl p-6 border border-white/5">
          <div class="w-12 h-12 bg-academy-teal/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
          </div>
          <h3 class="text-white font-bold mb-2">Daytime: Full Daycare</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">Structured play, outdoor time, socialization with matched groups, and supervised rest periods. Same routine as our daycare dogs.</p>
        </div>

        <div class="bg-brand-charcoal rounded-2xl p-6 border border-white/5">
          <div class="w-12 h-12 bg-academy-teal/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
          </div>
          <h3 class="text-white font-bold mb-2">Nighttime: Quiet & Comfortable</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">Private kennels with fresh bedding and water. Climate-controlled, secure facility. Your dog is settled and comfortable before lights out.</p>
        </div>

        <div class="bg-brand-charcoal rounded-2xl p-6 border border-white/5">
          <div class="w-12 h-12 bg-academy-teal/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          </div>
          <h3 class="text-white font-bold mb-2">Same Staff, Same Safety</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">Your dog is cared for by the same behaviour specialists they see during daycare. 15 years, perfect safety record — day and night.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 sm:py-24 bg-neutral-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">Boarding Reviews</span>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-charcoal mb-4">Travel With Confidence</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200/60">
            <div class="flex items-center gap-2 mb-4">
            <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" /><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" /><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" /><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" /></svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            </div>
            <p class="text-neutral-600 text-sm leading-relaxed mb-4">"{t.text}"</p>
            <div class="pt-3 border-t border-neutral-100">
              <p class="font-semibold text-brand-charcoal text-sm">{t.name}</p>
              <p class="text-xs text-neutral-400">{t.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 sm:py-24 bg-brand-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">FAQ</span>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">Boarding Questions</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-brand-charcoal rounded-xl border border-white/5 overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-6 hover:bg-white/5 transition-colors">
              <span class="text-base font-semibold text-white pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </summary>
            <div class="px-6 pb-6 text-neutral-400 leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>
