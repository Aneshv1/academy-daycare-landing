---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const includes = [
  { title: 'Essential Commands', desc: 'Sit, down, stay, come, place — trained to reliability in real-world situations' },
  { title: 'Calm on Command', desc: 'Elevated place cots for impulse control — your dog learns to settle on command' },
  { title: 'Loose Leash Walking', desc: 'Real-world leash manners, not just indoor compliance' },
  { title: 'Treadmill Fitness', desc: 'Controlled exercise for focus, endurance, and energy management' },
  { title: 'Full Daycare Access', desc: 'Structured socialization with temperament-matched groups between sessions' },
  { title: 'Customized to Your Dog', desc: 'Every program is tailored to your dog\'s specific needs and your goals' },
];

const testimonials = [
  {
    name: 'Mark T.',
    text: 'We enrolled our doodle in Day & Train because we didn\'t have time for weekend classes. After just a few weeks he was walking on a loose leash, doing place command, and actually settling at home. Daycare + training in one — genius.',
    detail: 'Goldendoodle, 1.5y',
  },
  {
    name: 'Rachel D.',
    text: 'I don\'t have time for separate training sessions on weekends. Day & Train solved everything. I drop my dog off in the morning, she gets trained AND socialized all day, and comes home tired and well-behaved.',
    detail: 'Husky mix, 2y',
  },
  {
    name: 'B. W.',
    text: 'Three weeks into Day & Train and Diesel is walking on a loose leash and doing place command. My wife cried the first time she saw the difference. We\'re lifers.',
    detail: 'Rottweiler, 3y',
  },
];

const faqs = [
  { q: 'What\'s the difference between Day & Train and regular daycare?', a: 'Day & Train includes dedicated 1-on-1 training sessions with our behaviour specialists throughout the day, plus treadmill fitness and place cot training. Your dog gets full obedience training AND socialization — all in one visit.' },
  { q: 'Can intact dogs do Day & Train?', a: 'Yes. Intact dogs are welcome in our Day & Train program where they receive individualized attention and are managed by our trainers throughout the day.' },
  { q: 'How long does it take to see results?', a: 'Most owners notice significant changes within 2–3 weeks. Commands, leash manners, and settling at home typically improve quickly. More complex behavioural work may take longer.' },
  { q: 'What tools do you use?', a: 'We use prong collars, e-collars, slip leads, and muzzles as needed. The e-collar delivers TENS unit-type muscle stimulation — the same technology used by chiropractors — not a shock. These tools establish clear communication and reliable responses.' },
  { q: 'How many days per week should my dog attend?', a: 'For best results, we recommend 3–5 days per week. Consistency is key — the more frequent the sessions, the faster and more reliable the results.' },
  { q: 'Do I get updates on my dog\'s progress?', a: 'Yes. Your trainer provides progress updates at pickup and can discuss your dog\'s training plan, what they worked on, and what to reinforce at home.' },
];
---

<Layout
  title="Day & Train Dog Training in Gormley, ON | Academy Daycare"
  description="Day & Train: full obedience training combined with daycare. 1-on-1 trainer sessions, treadmill fitness, place cot training. Drop off, pick up a trained dog. Gormley, ON."
  canonical="https://academydaycare.ca/day-and-train"
>
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-brand-dark pt-24 pb-16 sm:pt-28 sm:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-academy-teal/5 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full mb-6">
            <span class="px-2.5 py-0.5 bg-academy-teal text-white text-xs font-bold rounded-full">Most Popular</span>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <span class="text-white text-xs font-bold">4.9/5</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-black leading-[1.1] tracking-tight mb-4">
            <span class="text-white">A Board & Train —</span><br />
            <span class="bg-gradient-to-r from-academy-teal to-emerald-400 bg-clip-text text-transparent">Without the Boarding</span>
          </h1>

          <p class="text-xl text-academy-teal font-semibold mb-6">Drop off in the morning. Pick up a trained dog.</p>

          <div class="border-l-2 border-academy-teal/40 pl-4 mb-6">
            <p class="text-neutral-300 text-sm italic">"After 3 weeks, he walks on a loose leash and settles at home. My wife cried."</p>
            <p class="text-neutral-500 text-xs mt-1">— B.W., Rottweiler owner</p>
          </div>

          <p class="text-lg text-neutral-300 leading-relaxed mb-8 max-w-xl">
            Full obedience training with canine behaviour specialists — combined with daycare. Your dog gets 1-on-1 training sessions, treadmill fitness, and socialization. <strong class="text-white">All the results of a board & train, with none of the separation.</strong>
          </p>

          <div class="grid grid-cols-2 gap-x-6 gap-y-3 mb-8">
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">1-on-1 trainer daily</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Your dog comes home nightly</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Treadmill fitness</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Intact dogs welcome</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Customized program</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Results in 2–3 weeks</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 mb-6">
            <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 bg-academy-teal text-white text-base font-bold rounded-xl hover:bg-academy-teal-dark transition-all duration-200 shadow-lg shadow-academy-teal/25">
              Inquire About Day & Train
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
            <a href="tel:4377769563" class="inline-flex items-center justify-center px-8 py-4 border border-white/10 text-white text-base font-semibold rounded-xl hover:bg-white/5 transition-all duration-200">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              437-776-9563
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
            <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/5a111928-48be-47f7-bdfd-53ef726f6825/DSC09620.JPG" alt="Dog in Day and Train session" class="w-full h-auto object-cover aspect-[4/3]" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/40 via-transparent to-transparent"></div>
          </div>
          <div class="absolute -bottom-4 -left-4 sm:bottom-4 sm:left-4 bg-brand-charcoal border border-white/10 rounded-xl px-4 py-3 shadow-xl">
            <p class="text-white text-sm font-bold">Most Popular Program</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">What's Included</span>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-charcoal mb-4">Everything Your Dog Needs — In One Visit</h2>
        <p class="text-lg text-neutral-500">No weekend classes. No separate training sessions. It all happens while you're at work.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {includes.map((item) => (
          <div class="bg-neutral-50 rounded-2xl p-6 border border-neutral-200">
            <div class="w-10 h-10 bg-academy-teal/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-academy-teal" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            </div>
            <h3 class="text-brand-charcoal font-bold mb-1">{item.title}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 max-w-md mx-auto bg-brand-charcoal rounded-2xl border border-academy-teal/30 p-8 text-center">
        <span class="px-3 py-1 bg-academy-teal text-white text-xs font-bold rounded-full">Most Popular</span>
        <div class="mt-4 mb-2">
          <span class="text-5xl font-black text-white">$109</span>
          <span class="text-neutral-400 text-sm">/day</span>
        </div>
        <p class="text-sm text-neutral-400 mb-6">Training + full daycare included</p>
        <a href="#contact" class="block px-6 py-3 bg-academy-teal text-white text-sm font-bold rounded-lg hover:bg-academy-teal-dark transition-colors">
          Inquire Now
        </a>
        <p class="text-xs text-neutral-500 mt-4">Multi-day packs available — ask us for details</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 sm:py-24 bg-brand-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">Day & Train Results</span>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">Drop Off Hyper, Pick Up Calm</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div class="bg-brand-charcoal rounded-2xl p-6 border border-white/5">
            <div class="flex items-center gap-2 mb-4">
            <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" /><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" /><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" /><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" /></svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            </div>
            <p class="text-neutral-300 text-sm leading-relaxed mb-4">"{t.text}"</p>
            <div class="pt-3 border-t border-white/5">
              <p class="font-semibold text-white text-sm">{t.name}</p>
              <p class="text-xs text-neutral-500">{t.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 sm:py-24 bg-neutral-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">FAQ</span>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-charcoal mb-4">Day & Train Questions</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white rounded-xl border border-neutral-200 overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-6 hover:bg-neutral-50 transition-colors">
              <span class="text-base font-semibold text-brand-charcoal pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </summary>
            <div class="px-6 pb-6 text-neutral-600 leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>
