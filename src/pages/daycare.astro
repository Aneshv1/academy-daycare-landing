---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const daycareSchedule = [
  { time: '7:00 AM', activity: 'Drop-off & check-in', desc: 'Health check, settle into play group' },
  { time: '7:30 AM', activity: 'Morning free play', desc: 'Structured play with matched temperament groups' },
  { time: '9:30 AM', activity: 'Outdoor yard time', desc: 'Fresh air, potty break, supervised exercise' },
  { time: '10:30 AM', activity: 'Rest & water break', desc: 'Quiet time in dedicated rest zones' },
  { time: '11:00 AM', activity: 'Social play session', desc: 'Structured group activities & socialization' },
  { time: '12:00 PM', activity: 'Lunch & digestion rest', desc: '90-minute rest after meals for safe digestion' },
  { time: '1:30 PM', activity: 'Afternoon play rotation', desc: 'New play group combinations, enrichment' },
  { time: '3:00 PM', activity: 'Outdoor yard session', desc: 'Exercise and fresh air' },
  { time: '4:00 PM', activity: 'Cool-down & settle', desc: 'Place cot practice, calm activities' },
  { time: '5:00–8:00 PM', activity: 'Pickup window', desc: 'Report card on your dog\'s day' },
];

const testimonials = [
  {
    name: 'Sarah M.',
    text: 'I used to feel terrible leaving my dog home alone all day. Now he goes to Academy 4 days a week and I know he\'s having a better day than I am.',
    detail: 'German Shepherd, 3y',
  },
  {
    name: 'James K.',
    text: 'I visited 5 daycares before finding Academy. Every other place was just chaos. Here, the staff actively manage every interaction. 15-year safety record says it all.',
    detail: 'Belgian Malinois, 4y',
  },
  {
    name: 'Derek W.',
    text: 'My lab was destroying the house out of boredom while I worked. Three weeks of daycare and she was a completely different dog at home. Tired, happy, and not eating the couch.',
    detail: 'Labrador, 1y',
  },
];

const faqs = [
  { q: 'What are the requirements for daycare?', a: 'Dogs must be at least 16 weeks old, have their rabies vaccination, and be spayed/neutered. All dogs require an in-person assessment before enrollment.' },
  { q: 'Can intact dogs attend daycare?', a: 'Intact dogs cannot attend regular daycare but are welcome in our Day & Train program where they receive individualized attention.' },
  { q: 'How often should my dog attend?', a: 'For best results — especially for new or nervous dogs — we recommend 3–5 days per week for at least the first few months to build routine and confidence.' },
  { q: 'What happens during a typical day?', a: 'Dogs rotate through structured play sessions, outdoor yard time, rest periods, and socialization — all supervised by our behaviour specialists. See the full schedule above.' },
  { q: 'What is behavioural daycare?', a: 'Behavioural daycare is for dogs that need extra support — reactive, nervous, or high-energy dogs that require more hands-on management and smaller group sizes. Our trainers actively work with these dogs throughout the day.' },
  { q: 'My dog is nervous — will daycare help?', a: 'Absolutely. We match nervous dogs with calm, compatible playmates and recommend consistent attendance (3–5 days/week) to build lasting confidence in a safe environment.' },
];
---

<Layout
  title="Dog Daycare in Gormley, ON | Academy Daycare"
  description="Structured dog daycare supervised by canine behaviour specialists. Temperament-matched groups, 8,500 sq ft facility, 15-year perfect safety record. Gormley, ON."
  canonical="https://academydaycare.ca/daycare"
>
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-brand-dark pt-24 pb-16 sm:pt-28 sm:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-academy-teal/5 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full mb-6">
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <span class="text-white text-xs font-bold">4.9/5</span>
            <span class="text-neutral-400 text-xs">250+ Google Reviews</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-black leading-[1.1] tracking-tight mb-6">
            <span class="text-white">A Daycare Where Your Dog</span><br />
            <span class="bg-gradient-to-r from-academy-teal to-emerald-400 bg-clip-text text-transparent">Actually Thrives</span>
          </h1>

          <div class="border-l-2 border-academy-teal/40 pl-4 mb-6">
            <p class="text-neutral-300 text-sm italic">"I can finally focus at work without the guilt. He comes home tired and happy."</p>
            <p class="text-neutral-500 text-xs mt-1">— Sarah M., German Shepherd owner</p>
          </div>

          <p class="text-lg text-neutral-300 leading-relaxed mb-8 max-w-xl">
            Drop your dog off with canine behaviour specialists — not part-time babysitters. Temperament-matched groups, structured play, and <strong class="text-white">a perfect 15-year safety record.</strong>
          </p>

          <div class="grid grid-cols-2 gap-x-6 gap-y-3 mb-8">
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Matched by temperament</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Comes home calmer</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Structured play & rest</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Nervous dogs welcome</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">Outdoor yard access</span>
            </div>
            <div class="flex items-center gap-2.5">
              <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-neutral-300">8,500 sq ft facility</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 mb-6">
            <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 bg-academy-teal text-white text-base font-bold rounded-xl hover:bg-academy-teal-dark transition-all duration-200 shadow-lg shadow-academy-teal/25 hover:shadow-academy-teal/40 hover:-translate-y-0.5">
              Book Your Assessment
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
            <a href="tel:4377769563" class="inline-flex items-center justify-center px-8 py-4 border border-white/10 text-white text-base font-semibold rounded-xl hover:bg-white/5 transition-all duration-200">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              437-776-9563
            </a>
          </div>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            <span class="text-xs text-neutral-500 uppercase tracking-wider">Free consultation</span>
            <span class="text-neutral-700">|</span>
            <span class="text-xs text-neutral-500 uppercase tracking-wider">15 years experience</span>
            <span class="text-neutral-700">|</span>
            <span class="text-xs text-neutral-500 uppercase tracking-wider">Same day response</span>
          </div>
        </div>

        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
            <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/1e6ee81e-a0fb-4617-b587-ffdd856762b6/DSC07978.JPG" alt="Dogs playing at Academy Daycare" class="w-full h-auto object-cover aspect-[4/3]" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/40 via-transparent to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">Pricing</span>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-charcoal mb-4">Simple, Transparent Pricing</h2>
        <p class="text-lg text-neutral-500">No hidden fees. Every day includes full facility access, structured play, and expert supervision.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <!-- Standard Daycare -->
        <div class="bg-neutral-50 rounded-2xl border border-neutral-200 p-8">
          <h3 class="text-xl font-bold text-brand-charcoal mb-1">Standard Daycare</h3>
          <p class="text-sm text-neutral-500 mb-6">For well-socialized dogs</p>
          <div class="mb-6">
            <span class="text-4xl font-black text-brand-charcoal">$55</span>
            <span class="text-neutral-500 text-sm">/day</span>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-2 text-sm text-neutral-600">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Temperament-matched play groups
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-600">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Outdoor yard access
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-600">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Structured rest periods
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-600">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Expert supervision all day
            </li>
          </ul>
          <a href="#contact" class="block text-center px-6 py-3 bg-academy-teal text-white text-sm font-bold rounded-lg hover:bg-academy-teal-dark transition-colors">
            Inquire Now
          </a>
        </div>

        <!-- Behavioural Daycare -->
        <div class="bg-brand-charcoal rounded-2xl border border-academy-teal/30 p-8 relative">
          <div class="absolute top-4 right-4">
            <span class="px-3 py-1 bg-academy-teal text-white text-xs font-bold rounded-full">Specialized</span>
          </div>
          <h3 class="text-xl font-bold text-white mb-1">Behavioural Daycare</h3>
          <p class="text-sm text-neutral-400 mb-6">For reactive, nervous, or high-energy dogs</p>
          <div class="mb-6">
            <span class="text-4xl font-black text-white">$95</span>
            <span class="text-neutral-400 text-sm">/day</span>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
