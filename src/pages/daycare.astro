      <p class="text-center text-sm text-neutral-400 mt-6">Pricing for add-ons available at check-in. <a href="#contact" class="text-academy-teal hover:underline">Ask us for details.</a></p>
    </div>
  </section>

  <!-- Daily Schedule -->
  <section class="py-20 sm:py-24 bg-brand-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">A Typical Day</span>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">What Your Dog's Day Looks Like</h2>
        <p class="text-lg text-neutral-400">Structure, play, rest, repeat. No guessing — here's exactly what happens.</p>
      </div>

      <div class="bg-brand-charcoal rounded-2xl border border-white/5 p-6 sm:p-8">
        <div class="space-y-0">
          {daycareSchedule.map((item, i) => (
            <div class={`flex gap-4 sm:gap-6 py-4 ${i < daycareSchedule.length - 1 ? 'border-b border-white/5' : ''}`}>
              <div class="w-24 sm:w-28 flex-shrink-0">
                <span class="text-sm font-bold text-academy-teal">{item.time}</span>
              </div>
              <div>
                <p class="text-sm font-semibold text-white">{item.activity}</p>
                <p class="text-xs text-neutral-400 mt-0.5">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 sm:py-24 bg-neutral-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">What Daycare Parents Say</span>
        <h2 class="text-3xl sm:text-4xl font-black text-brand-charcoal mb-4">Peace of Mind, Every Day</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200/60">
            <div class="flex items-center gap-2 mb-4">
            <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" /><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" /><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" /><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" /></svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            </div>
            <p class="text-neutral-600 text-sm leading-relaxed mb-4">"{t.text}"</p>
            <div class="pt-3 border-t border-neutral-100">
              <p class="font-semibold text-brand-charcoal text-sm">{t.name}</p>
              <p class="text-xs text-neutral-400">{t.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 sm:py-24 bg-brand-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">FAQ</span>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">Daycare Questions</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-brand-charcoal rounded-xl border border-white/5 overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-6 hover:bg-white/5 transition-colors">
              <span class="text-base font-semibold text-white pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </summary>
            <div class="px-6 pb-6 text-neutral-400 leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>
