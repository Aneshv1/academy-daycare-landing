---
---

<section class="relative bg-brand-dark pt-24 pb-16 sm:pt-28 sm:pb-20 overflow-hidden">
  <!-- Subtle gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-academy-teal/5 via-transparent to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <!-- Google Review Pill -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full mb-6">
          <svg class="w-4 h-4" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          <div class="flex items-center gap-0.5">
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          </div>
          <span class="text-white text-xs font-bold">4.9/5</span>
          <span class="text-neutral-400 text-xs">250+ Google Reviews</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight mb-6">
          <span class="text-white">Peace of Mind</span><br />
          <span class="bg-gradient-to-r from-academy-teal to-emerald-400 bg-clip-text text-transparent">While You Work</span>
        </h1>

        <!-- Quote Badge -->
        <div class="border-l-2 border-academy-teal/40 pl-4 mb-6">
          <p class="text-neutral-300 text-sm italic leading-relaxed">"My dog was banned from 2 daycares. Academy didn't just accept him — he's thriving now."</p>
          <p class="text-neutral-500 text-xs mt-1">— Sarah M., German Shepherd owner</p>
        </div>

        <p class="text-lg sm:text-xl text-neutral-300 leading-relaxed mb-8 max-w-xl">
          Drop your dog off with canine behaviour specialists — not part-time babysitters. 8,500 sq ft of structured play, expert training, and <strong class="text-white">a perfect 15-year safety record.</strong>
        </p>

        <!-- Outcome Checklist — 6 items in 2-col grid -->
        <div class="grid grid-cols-2 gap-x-6 gap-y-3 mb-8">
          <div class="flex items-center gap-2.5">
            <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-neutral-300">Comes home calmer</span>
          </div>
          <div class="flex items-center gap-2.5">
            <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-neutral-300">Builds real confidence</span>
          </div>
          <div class="flex items-center gap-2.5">
            <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-neutral-300">Matched by temperament</span>
          </div>
          <div class="flex items-center gap-2.5">
            <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-neutral-300">Nervous dogs welcome</span>
          </div>
          <div class="flex items-center gap-2.5">
            <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-neutral-300">Every dog assessed first</span>
          </div>
          <div class="flex items-center gap-2.5">
            <svg class="w-5 h-5 text-academy-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-neutral-300">Training available too</span>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 bg-academy-teal text-white text-base font-bold rounded-xl hover:bg-academy-teal-dark transition-all duration-200 shadow-lg shadow-academy-teal/25 hover:shadow-academy-teal/40 hover:-translate-y-0.5">
            Book Your Assessment
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="tel:4377769563" class="inline-flex items-center justify-center px-8 py-4 border border-white/10 text-white text-base font-semibold rounded-xl hover:bg-white/5 transition-all duration-200">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            437-776-9563
          </a>
        </div>

        <!-- Trust Line -->
        <div class="flex flex-wrap gap-x-4 gap-y-2">
          <span class="text-xs text-neutral-500 uppercase tracking-wider">Free consultation</span>
          <span class="text-neutral-700">|</span>
          <span class="text-xs text-neutral-500 uppercase tracking-wider">15 years experience</span>
          <span class="text-neutral-700">|</span>
          <span class="text-xs text-neutral-500 uppercase tracking-wider">Same day response</span>
        </div>
      </div>

      <!-- Right: Hero Image -->
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
          <img
            src="/hero.jpg"
            alt="Dogs playing at Academy Daycare"
            class="w-full h-auto object-cover aspect-[4/3]"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/40 via-transparent to-transparent"></div>
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 sm:bottom-4 sm:left-4 bg-brand-charcoal border border-white/10 rounded-xl px-4 py-3 shadow-xl">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-academy-teal/20 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-academy-teal" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M9.661 2.237a.531.531 0 01.678 0 11.947 11.947 0 007.078 2.749.5.5 0 01.479.425c.069.52.104 1.05.104 1.59 0 5.162-3.26 9.563-7.834 11.256a.48.48 0 01-.332 0C5.26 16.564 2 12.163 2 7c0-.538.035-1.069.104-1.589a.5.5 0 01.48-.425 11.947 11.947 0 007.077-2.75z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <p class="text-white text-sm font-bold">Safest Daycare in the GTA</p>
              <p class="text-neutral-400 text-xs">Perfect record, 15 years</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="mt-16 sm:mt-20 grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8 py-8 px-6 bg-brand-charcoal/50 rounded-2xl border border-white/5">
      <div class="text-center">
        <p class="text-2xl sm:text-3xl font-black text-white">8,500<span class="text-academy-teal">sqft</span></p>
        <p class="text-xs sm:text-sm text-neutral-400 mt-1">Premium Facility</p>
      </div>
      <div class="text-center">
        <p class="text-2xl sm:text-3xl font-black text-white">15</p>
        <p class="text-xs sm:text-sm text-neutral-400 mt-1">Years Experience</p>
      </div>
      <div class="text-center">
        <p class="text-2xl sm:text-3xl font-black text-white">100<span class="text-academy-teal">%</span></p>
        <p class="text-xs sm:text-sm text-neutral-400 mt-1">Safety Record</p>
      </div>
      <div class="text-center">
        <p class="text-2xl sm:text-3xl font-black text-white">7<span class="text-academy-teal">am</span>–8<span class="text-academy-teal">pm</span></p>
        <p class="text-xs sm:text-sm text-neutral-400 mt-1">Mon–Fri</p>
      </div>
    </div>
  </div>
</section>
