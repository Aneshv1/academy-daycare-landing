---
---

<section id="programs" class="py-20 sm:py-24 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">Our Programs</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4">
        More Than Just a Daycare
      </h2>
      <p class="text-lg text-neutral-400">
        Every program is designed and supervised by canine behaviour specialists. Your dog gets expert attention — not just a place to sit.
      </p>
    </div>

    <!-- Program Cards -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- Daycare -->
      <div class="group relative bg-brand-charcoal rounded-2xl border border-white/5 overflow-hidden hover:border-academy-teal/30 transition-all duration-300">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/1e6ee81e-a0fb-4617-b587-ffdd856762b6/DSC07978.JPG" alt="Dogs playing at daycare" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 bg-academy-teal/10 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-academy-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white">Daycare</h3>
          </div>
          <p class="text-sm text-neutral-400 mb-4 leading-relaxed">
            Structured play with compatible playmates, outdoor yard time, and expert supervision. Your dog learns social etiquette while having the time of their life.
          </p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Separated play areas by temperament
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Secured outdoor run
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Quiet kennels for rest periods
            </li>
          </ul>
          <a href="#contact" class="inline-flex items-center text-sm font-semibold text-academy-teal hover:text-emerald-400 transition-colors">
            Inquire Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>

      <!-- Day & Train -->
      <div class="group relative bg-brand-charcoal rounded-2xl border border-academy-teal/30 overflow-hidden hover:border-academy-teal/50 transition-all duration-300">
        <div class="absolute top-4 right-4 z-10">
          <span class="px-3 py-1 bg-academy-teal text-white text-xs font-bold rounded-full">Most Popular</span>
        </div>
        <div class="aspect-[4/3] overflow-hidden">
          <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/5a111928-48be-47f7-bdfd-53ef726f6825/DSC09620.JPG" alt="Dog in Day and Train session" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 bg-academy-teal/10 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-academy-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white">Day & Train</h3>
          </div>
          <p class="text-sm text-neutral-400 mb-1 leading-relaxed">
            <span class="text-white font-semibold">A Board & Train — without the boarding.</span>
          </p>
          <p class="text-sm text-neutral-400 mb-4 leading-relaxed">
            Full obedience training combined with daycare. Your dog learns commands, calm-on-command, and loose leash walking with one-on-one trainer attention.
          </p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              1-on-1 trainer sessions daily
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Treadmill fitness + place cot training
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Intact dogs welcome
            </li>
          </ul>
          <a href="#contact" class="inline-flex items-center text-sm font-semibold text-academy-teal hover:text-emerald-400 transition-colors">
            Inquire Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>

      <!-- Training -->
      <div class="group relative bg-brand-charcoal rounded-2xl border border-white/5 overflow-hidden hover:border-academy-teal/30 transition-all duration-300">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/3ecfe2e8-98bc-4d9e-a8d6-ee9c63482dca/DSC08366-2.jpg" alt="Dog on place cot during training" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 bg-academy-teal/10 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-academy-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white">Training</h3>
          </div>
          <p class="text-sm text-neutral-400 mb-4 leading-relaxed">
            Full obedience training with canine behaviour specialists. Customized programs tailored to your dog's specific needs and your training goals.
          </p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Customized to your dog
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Behaviour specialist led
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Commands, markers & more
            </li>
          </ul>
          <a href="#contact" class="inline-flex items-center text-sm font-semibold text-academy-teal hover:text-emerald-400 transition-colors">
            Inquire Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>

      <!-- Boarding -->
      <div class="group relative bg-brand-charcoal rounded-2xl border border-white/5 overflow-hidden hover:border-academy-teal/30 transition-all duration-300">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/e8e502cd-4f6b-4f0e-b57c-e24c072d73fb/440547A1-5801-4012-A881-28733D746BEF.JPG" alt="Dog resting in quiet kennel" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 bg-academy-teal/10 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-academy-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white">Boarding</h3>
          </div>
          <p class="text-sm text-neutral-400 mb-4 leading-relaxed">
            Leave your dog in expert hands while you travel. Full facility access, structured routines, and the same level of supervision as our daycare program.
          </p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Full daycare activities included
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Quiet private kennels
            </li>
            <li class="flex items-start gap-2 text-sm text-neutral-300">
              <svg class="w-4 h-4 text-academy-teal mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              Structured daily routine
            </li>
          </ul>
          <a href="#contact" class="inline-flex items-center text-sm font-semibold text-academy-teal hover:text-emerald-400 transition-colors">
            Inquire Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
