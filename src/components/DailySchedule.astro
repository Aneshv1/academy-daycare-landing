---
const daycareSchedule = [
  { time: '7:00–10:00 AM', activity: 'Drop-off & check-in', desc: 'Health check, settle into play group' },
  { time: '7:30 AM', activity: 'Morning free play', desc: 'Structured play with matched temperament groups' },
  { time: '9:30 AM', activity: 'Outdoor yard time', desc: 'Fresh air, potty break, supervised exercise' },
  { time: '10:30 AM', activity: 'Rest & water break', desc: 'Quiet time in dedicated rest zones' },
  { time: '11:00 AM', activity: 'Social play session', desc: 'Structured group activities & socialization' },
  { time: '12:00 PM', activity: 'Lunch & digestion rest', desc: 'Puppy lunch if provided. 90-minute mandatory rest' },
  { time: '1:30 PM', activity: 'Afternoon play rotation', desc: 'New play group combinations, enrichment' },
  { time: '3:00 PM', activity: 'Outdoor yard session', desc: 'Exercise and fresh air' },
  { time: '4:00 PM', activity: 'Cool-down & settle', desc: 'Calm activities, winding down' },
  { time: '3:00–8:00 PM', activity: 'Pickup window', desc: 'Weekly report card on your dog\'s progress' },
];

const dayTrainSchedule = [
  { time: '7:00–10:00 AM', activity: 'Drop-off & check-in', desc: 'Health check, morning assessment' },
  { time: '7:30 AM', activity: '1-on-1 training session', desc: 'Commands, markers, leash work with trainer' },
  { time: '9:00 AM', activity: 'Treadmill fitness', desc: 'Controlled exercise for focus & energy management' },
  { time: '9:45 AM', activity: 'Social play session', desc: 'Structured play with matched temperament groups' },
  { time: '10:30 AM', activity: 'Place cot training', desc: 'Calm-on-command, impulse control practice' },
  { time: '11:30 AM', activity: '2nd training session', desc: 'Reinforcement, real-world distraction work' },
  { time: '12:30 PM', activity: 'Lunch & digestion rest', desc: '90-minute rest period' },
  { time: '2:00 PM', activity: 'Afternoon play rotation', desc: 'Socialization with daycare groups' },
  { time: '3:00 PM', activity: 'Outdoor leash work', desc: 'Loose leash walking practice in the yard' },
  { time: '4:00 PM', activity: 'Cool-down & settle', desc: 'Final place cot session, decompression' },
  { time: '3:00–8:00 PM', activity: 'Pickup window', desc: 'Training progress update from your trainer' },
];
---

<section id="schedule" class="py-20 sm:py-24 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">What a Day Looks Like</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4">
        A Day at Academy
      </h2>
      <p class="text-lg text-neutral-400">
        Structure, play, rest, repeat. Here's exactly what your dog's day looks like — no guessing.
      </p>
    </div>

    <!-- Two columns: Daycare + Day & Train -->
    <div class="grid lg:grid-cols-2 gap-8">

      <!-- Daycare Schedule -->
      <div class="bg-neutral-50 rounded-2xl border border-neutral-200 overflow-hidden">
        <div class="bg-academy-teal px-6 py-4">
          <h3 class="text-lg font-bold text-white">Daycare</h3>
          <p class="text-sm text-white/70">Structured play & socialization</p>
        </div>
        <div class="p-6">
          <div class="space-y-4">
            {daycareSchedule.map((item) => (
              <div class="flex gap-4">
                <div class="w-20 flex-shrink-0">
                  <span class="text-sm font-bold text-academy-teal">{item.time}</span>
                </div>
                <div class="flex-1 pb-4 border-b border-neutral-100 last:border-0">
                  <p class="text-sm font-semibold text-brand-charcoal">{item.activity}</p>
                  <p class="text-xs text-neutral-500 mt-0.5">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Day & Train Schedule -->
      <div class="bg-neutral-50 rounded-2xl border border-neutral-200 overflow-hidden">
        <div class="bg-brand-charcoal px-6 py-4">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-lg font-bold text-white">Day & Train</h3>
              <p class="text-sm text-neutral-400">Training + daycare combined</p>
            </div>
            <span class="px-3 py-1 bg-academy-teal text-white text-xs font-bold rounded-full">Most Popular</span>
          </div>
        </div>
        <div class="p-6">
          <div class="space-y-4">
            {dayTrainSchedule.map((item) => (
              <div class="flex gap-4">
                <div class="w-20 flex-shrink-0">
                  <span class="text-sm font-bold text-academy-teal">{item.time}</span>
                </div>
                <div class="flex-1 pb-4 border-b border-neutral-100 last:border-0">
                  <p class="text-sm font-semibold text-brand-charcoal">{item.activity}</p>
                  <p class="text-xs text-neutral-500 mt-0.5">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
