---
---

<section class="py-16 sm:py-20 bg-neutral-50 border-y border-neutral-200">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-black text-brand-charcoal mb-2">Before You Apply</h2>
      <p class="text-neutral-500">A few things to know about enrollment at Academy Daycare</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="text-center">
        <div class="w-14 h-14 bg-academy-teal/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
        </div>
        <h3 class="text-brand-charcoal font-bold mb-1">16+ Weeks Old</h3>
        <p class="text-neutral-500 text-sm">Minimum age requirement for all programs</p>
      </div>

      <div class="text-center">
        <div class="w-14 h-14 bg-academy-teal/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <h3 class="text-brand-charcoal font-bold mb-1">Rabies Vaccine</h3>
        <p class="text-neutral-500 text-sm">Required vaccination before first visit</p>
      </div>

      <div class="text-center">
        <div class="w-14 h-14 bg-academy-teal/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </div>
        <h3 class="text-brand-charcoal font-bold mb-1">We Take Any Dog</h3>
        <p class="text-neutral-500 text-sm">15 years experience, no dog turned away</p>
      </div>

      <div class="text-center">
        <div class="w-14 h-14 bg-academy-teal/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-brand-charcoal font-bold mb-1">Mon–Fri Hours</h3>
        <p class="text-neutral-500 text-sm">Open 7:00 AM to 8:00 PM</p>
      </div>
    </div>
  </div>
</section>
