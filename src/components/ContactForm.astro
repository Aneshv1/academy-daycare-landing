---

<section id="contact" class="py-20 sm:py-24 bg-neutral-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16">
      <!-- Left: Copy -->
      <div>
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">Start Here</span>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">
          Give Your Dog the Care They Actually Deserve
        </h2>
        <p class="text-lg text-neutral-400 mb-8 leading-relaxed">
          Fill out the form and our team reaches out — usually same day. From there, we book your dog's in-person assessment and find the perfect program.
        </p>

        <div class="space-y-6 mb-8">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-academy-teal/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold">22 Cardico Dr</p>
              <p class="text-neutral-400 text-sm">Gormley, ON</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-academy-teal/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold">Mon–Fri, 7:00 AM – 8:00 PM
Drop-off 7–10 AM · Pickup 3–8 PM</p>
              <p class="text-neutral-400 text-sm">Sat–Sun Closed</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-academy-teal/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <a href="tel:4377769563" class="text-white font-semibold hover:text-academy-teal transition-colors">437-776-9563</a>
              <p class="text-neutral-400 text-sm">Usually same day response</p>
            </div>
          </div>
        </div>

        <!-- Google Maps -->
        <div class="rounded-xl overflow-hidden border border-white/5 mt-2">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2873.0!2d-79.37!3d44.0!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s22+Cardico+Dr%2C+Gormley%2C+ON!5e0!3m2!1sen!2sca!4v1700000000000"
            width="100%"
            height="200"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Academy Daycare location"
          ></iframe>
        </div>
      </div>

      <!-- Right: Form -->
      <div>
        <form id="inquiry-form" class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="owner_name" class="block text-sm font-medium text-neutral-300 mb-1.5">Your Name</label>
              <input type="text" id="owner_name" name="owner_name" required
                class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-academy-teal focus:border-transparent transition-all"
                placeholder="Full name" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-neutral-300 mb-1.5">Phone</label>
              <input type="tel" id="phone" name="phone" required
                class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-academy-teal focus:border-transparent transition-all"
                placeholder="Your phone number" />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-neutral-300 mb-1.5">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-academy-teal focus:border-transparent transition-all"
              placeholder="your@email.com" />
          </div>

          <div>
            <label for="dog_info" class="block text-sm font-medium text-neutral-300 mb-1.5">Dog's Name, Age & Breed</label>
            <input type="text" id="dog_info" name="dog_info" required
              class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-academy-teal focus:border-transparent transition-all"
              placeholder="e.g. Max, 2 years, German Shepherd" />
          </div>

          <div>
            <label for="service" class="block text-sm font-medium text-neutral-300 mb-1.5">Program Interest</label>
            <select id="service" name="service" required
              class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-academy-teal focus:border-transparent transition-all">
              <option value="" class="text-neutral-500">Select a program</option>
              <option value="daycare">Daycare</option>
              <option value="day-and-train">Day & Train</option>
              <option value="training">Training</option>
              <option value="boarding">Boarding</option>
              <option value="not-sure">Not Sure Yet</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-neutral-300 mb-1.5">Tell Us About Your Dog</label>
            <textarea id="message" name="message" rows="3"
              class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-academy-teal focus:border-transparent transition-all resize-none"
              placeholder="Any behavioural concerns, goals, or questions..."></textarea>
          </div>

          <button type="submit" id="submit-btn"
            class="w-full px-8 py-4 bg-academy-teal text-white text-base font-bold rounded-xl hover:bg-academy-teal-dark transition-all duration-200 shadow-lg shadow-academy-teal/25 hover:shadow-academy-teal/40">
            Start My Dog's Assessment
          </button>
        </form>

        <!-- Social proof under form -->
        <div class="mt-6 flex items-start gap-3 p-4 bg-neutral-800/50 rounded-xl border border-white/5">
          <div class="flex items-center gap-0.5 flex-shrink-0 mt-0.5">
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          </div>
          <div>
            <p class="text-neutral-300 text-sm leading-relaxed">"My dog was banned from 2 daycares. Academy didn't just accept him — he's thriving now."</p>
            <p class="text-neutral-500 text-xs mt-1">— Sarah M., German Shepherd owner</p>
          </div>
        </div>

        <!-- Success State -->
        <div id="success-message" class="hidden text-center py-12">
          <div class="w-16 h-16 bg-academy-teal/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-academy-teal" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-2">Inquiry Received</h3>
          <p class="text-neutral-400">Our team will review your submission and get back to you — usually same day.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('inquiry-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('success-message') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      // Submit to API
      const res = await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!res.ok) throw new Error('Submission failed');

      // Push to Klaviyo
      const _learnq = (window as any)._learnq || [];
      _learnq.push(['identify', {
        '$email': data.email,
        '$first_name': (data.owner_name as string).split(' ')[0],
        '$last_name': (data.owner_name as string).split(' ').slice(1).join(' '),
        '$phone_number': data.phone,
        'Dog Info': data.dog_info,
        'Service Interest': data.service,
        'Source': 'Academy Daycare Landing Page',
      }]);
      _learnq.push(['track', 'Daycare Inquiry', {
        'Service': data.service,
        'Dog Info': data.dog_info,
        'Message': data.message,
        'Source': 'Academy Daycare Landing Page',
      }]);

      // Show success
      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
    } catch (err) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Start My Dog\'s Assessment';
      alert('Something went wrong. Please call us at 437-776-9563.');
    }
  });
</script>
