---
---

<section id="facility" class="py-20 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">Our Facility</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-brand-charcoal mb-4">
        8,500 Sq Ft Built for Dogs
      </h2>
      <p class="text-lg text-neutral-500">
        Purpose-designed spaces for play, training, rest, and fitness. Every area serves a function.
      </p>
    </div>

    <!-- Feature Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-academy-teal/20 hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-academy-teal/10 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-brand-charcoal mb-2">Separated Play Zones — So Every Dog Plays Safely</h3>
        <p class="text-neutral-500 leading-relaxed">
          Separated zones ensure dogs play with compatible temperaments and sizes. Every group is carefully curated for safety.
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-academy-teal/20 hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-academy-teal/10 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-brand-charcoal mb-2">Fresh Air & Exercise — Without the Risk</h3>
        <p class="text-neutral-500 leading-relaxed">
          Spacious outdoor yard for exercise, potty breaks, and fresh air. Fully fenced and supervised at all times.
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-academy-teal/20 hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-academy-teal/10 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-brand-charcoal mb-2">Your Dog Actually Rests — Not Just Runs All Day</h3>
        <p class="text-neutral-500 leading-relaxed">
          Dedicated quiet zones with fresh water for scheduled rest periods. Dogs get a 90-minute break after meals for safe digestion.
        </p>
      </div>

      <!-- Feature 4 -->
      <div class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-academy-teal/20 hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-academy-teal/10 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-brand-charcoal mb-2">Burn Energy the Right Way — Controlled Treadmill Sessions</h3>
        <p class="text-neutral-500 leading-relaxed">
          Professional dog treadmills for controlled exercise sessions. Perfect for high-energy dogs in our Day & Train program.
        </p>
      </div>

      <!-- Feature 5 -->
      <div class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-academy-teal/20 hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-academy-teal/10 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-brand-charcoal mb-2">Emergencies Handled — Staff Trained in Canine First Aid</h3>
        <p class="text-neutral-500 leading-relaxed">
          Every team member is trained and equipped to provide first aid. We maintain direct contact with nearby emergency veterinary clinics.
        </p>
      </div>

      <!-- Feature 6 -->
      <div class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-academy-teal/20 hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 bg-academy-teal/10 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-academy-teal" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-brand-charcoal mb-2">Your Dog Learns to Settle — A Skill That Transfers Home</h3>
        <p class="text-neutral-500 leading-relaxed">
          Training cots throughout the facility for calm-on-command practice. Dogs learn to settle and relax on command — a skill that transfers home.
        </p>
      </div>
    </div>

    <!-- Facility Photo Strip -->
    <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="rounded-xl overflow-hidden aspect-square">
        <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/bdc5816a-e151-422c-b094-fdb7850f4e33/Slapmill+-+blue.png" alt="Dog on treadmill" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
      </div>
      <div class="rounded-xl overflow-hidden aspect-square">
        <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/1e6ee81e-a0fb-4617-b587-ffdd856762b6/DSC07978.JPG" alt="Dogs playing" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
      </div>
      <div class="rounded-xl overflow-hidden aspect-square">
        <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/3ecfe2e8-98bc-4d9e-a8d6-ee9c63482dca/DSC08366-2.jpg" alt="Dog on place cot" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
      </div>
      <div class="rounded-xl overflow-hidden aspect-square">
        <img src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/fb468606-a34f-4d8e-8dd0-ae7054204930/IMG_7210.jpg" alt="Dog at facility" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
      </div>
    </div>
  </div>
</section>
