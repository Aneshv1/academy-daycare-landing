---
---

<section class="py-20 sm:py-24 bg-brand-charcoal">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Image -->
      <div class="relative order-2 lg:order-1">
        <div class="rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
          <img
            src="https://images.squarespace-cdn.com/content/v1/640b7e539788904338695107/5a111928-48be-47f7-bdfd-53ef726f6825/DSC09620.JPG"
            alt="Dog in Day and Train session"
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </div>
        <div class="absolute -top-4 -right-4 sm:top-4 sm:right-4 bg-academy-teal rounded-xl px-5 py-3 shadow-xl">
          <p class="text-white text-sm font-bold">Most Popular Program</p>
        </div>
      </div>

      <!-- Right: Copy -->
      <div class="order-1 lg:order-2">
        <span class="inline-block text-academy-teal text-sm font-semibold uppercase tracking-wider mb-3">Featured Program</span>
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-2">
          Day & Train
        </h2>
        <p class="text-xl text-academy-teal font-semibold mb-6">A Board & Train — Without the Boarding.</p>

        <p class="text-lg text-neutral-400 mb-8 leading-relaxed">
          Your dog gets full-scale obedience training and fitness with canine behaviour specialists — then comes home to you every night. All the results of a board and train, with none of the separation.
        </p>

        <div class="grid sm:grid-cols-2 gap-4 mb-8">
          <div class="bg-neutral-800/50 rounded-xl p-4 border border-white/5">
            <h4 class="text-white font-semibold text-sm mb-1">Essential Commands</h4>
            <p class="text-neutral-400 text-xs">Sit, down, stay, come, place — trained to reliability</p>
          </div>
          <div class="bg-neutral-800/50 rounded-xl p-4 border border-white/5">
            <h4 class="text-white font-semibold text-sm mb-1">Calm on Command</h4>
            <p class="text-neutral-400 text-xs">Elevated place cots for impulse control and settling</p>
          </div>
          <div class="bg-neutral-800/50 rounded-xl p-4 border border-white/5">
            <h4 class="text-white font-semibold text-sm mb-1">Loose Leash Walking</h4>
            <p class="text-neutral-400 text-xs">Real-world leash manners, not just indoor compliance</p>
          </div>
          <div class="bg-neutral-800/50 rounded-xl p-4 border border-white/5">
            <h4 class="text-white font-semibold text-sm mb-1">Treadmill Fitness</h4>
            <p class="text-neutral-400 text-xs">Controlled exercise for high-energy dogs</p>
          </div>
        </div>

        <div class="bg-neutral-800/30 rounded-xl p-5 border border-white/5 mb-8">
          <p class="text-neutral-300 text-sm leading-relaxed">
            <span class="text-white font-semibold">Completely customizable</span> to each dog's needs and training goals. Intact dogs are welcome in this program.
          </p>
        </div>

        <a href="#contact" class="inline-flex items-center px-8 py-4 bg-academy-teal text-white text-base font-bold rounded-xl hover:bg-academy-teal-dark transition-all duration-200 shadow-lg shadow-academy-teal/25 hover:shadow-academy-teal/40 hover:-translate-y-0.5">
          Inquire About Day & Train
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
